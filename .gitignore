# Node dependencies
node_modules/

# Astro generated types & cache
.astro/

# Astro build output — regenerated by `npm run build` and embedded into the
# binary at image-build time. Only the (empty) .gitkeep is tracked, so the embed
# dir exists on a fresh checkout; the build's `postbuild` step restores it after
# each build (Astro empties dist/ on every build).
/web/dist/*
!/web/dist/.gitkeep

# LaTeX build artifacts from the CV source (web/cv/primary_cv.tex). The source
# .tex is tracked; the compiled PDF is published as web/public/resume.pdf (also
# tracked), so the intermediate PDF and aux files here are throwaway.
/web/cv/*.aux
/web/cv/*.log
/web/cv/*.out
/web/cv/*.fls
/web/cv/*.fdb_latexmk
/web/cv/*.synctex.gz
/web/cv/primary_cv.pdf

# Go build artifacts
/portfolio
/out/
*.test

# Editor / OS noise
.DS_Store
*.swp

writing_style.md
human-register-revision-guide.md
