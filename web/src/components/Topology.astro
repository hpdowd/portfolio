---
/**
 * Topology — the home view as a live system diagram.
 *
 * The page IS the homelab: a hand-drawn SVG of the real CD pipeline (push →
 * mirror/build → registry → GitOps → THIS pod → scraped back into
 * VictoriaMetrics). Node colour is live health, sourced from the same /api the
 * cluster serves. Three nodes are directly probed (portfolio responds at all,
 * VM answered the status query, Gitea answered the git query); the structural
 * infra nodes are coloured from the cluster aggregate (all targets up + no
 * alerts ⇒ green). The portfolio node shows its own request rate — the
 * recursion, made visible.
 *
 * Accessibility: the SVG carries the desktop experience; a semantic outline
 * list carries mobile + screen readers. Exactly one is displayed at a time, so
 * the a11y tree never sees both. Motion is a single slow pulse on live dots,
 * disabled under prefers-reduced-motion.
 */

// One source of truth for both the SVG nodes and the outline list. `probe`
// marks the directly-probed nodes; `kind` drives styling.
const NODE_W = 150;
const NODE_H = 64;
const nodes = [
  { id: 'henry',     x: 24,  y: 44,  label: 'henry',           sub: 'platform · sre', kind: 'identity' },
  { id: 'gitea',     x: 248, y: 44,  label: 'Gitea',           sub: 'source of truth', kind: 'probed', probe: 'gitea' },
  { id: 'actions',   x: 472, y: 44,  label: 'GitHub Actions',  sub: 'build',          kind: 'infra' },
  { id: 'ghcr',      x: 696, y: 44,  label: 'GHCR',            sub: 'registry',       kind: 'infra' },
  { id: 'argocd',    x: 248, y: 212, label: 'ArgoCD',          sub: 'GitOps deploy',  kind: 'infra' },
  { id: 'portfolio', x: 472, y: 212, label: 'portfolio',       sub: '— req/s',        kind: 'self',  probe: 'portfolio' },
  { id: 'vm',        x: 696, y: 212, label: 'VictoriaMetrics', sub: 'observability',  kind: 'probed', probe: 'vm' },
] as const;
---

<section class="topo" aria-label="Homelab — live system topology">
  <header class="topo__head">
    <div>
      <p class="topo__kicker">Platform · DevOps · SRE</p>
      <h1 class="topo__title">Henry Dowd</h1>
    </div>
    <p class="topo__live" aria-live="polite">
      <span class="topo__dot" data-dot="cluster" aria-hidden="true"></span>
      <span data-cluster>connecting…</span>
    </p>
  </header>

  <div class="topo__stage">
    <!-- Desktop: the diagram. Hidden from the a11y tree on small screens. -->
    <svg class="topo__svg" viewBox="0 0 880 360" role="img"
         aria-label="Diagram of the homelab continuous-delivery pipeline: henry pushes to Gitea, which mirrors to GitHub Actions to build and push to GHCR; ArgoCD watches Gitea and deploys the portfolio pod, which pulls its image from GHCR and is scraped by VictoriaMetrics.">
      <defs>
        <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0,0 L10,5 L0,10 z" class="arrowhead" />
        </marker>
        <marker id="arrowA" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0,0 L10,5 L0,10 z" class="arrowhead arrowhead--accent" />
        </marker>
      </defs>

      <!-- Edges (absolute coords; orthogonal routing) -->
      <g class="edges">
        <path class="edge" d="M174,76 H248" marker-end="url(#arrow)" />
        <path class="edge" d="M398,76 H472" marker-end="url(#arrow)" />
        <path class="edge" d="M622,76 H696" marker-end="url(#arrow)" />
        <path class="edge" d="M323,108 V212" marker-end="url(#arrow)" />
        <path class="edge" d="M771,108 V160 H547 V212" marker-end="url(#arrow)" />
        <path class="edge" d="M398,244 H472" marker-end="url(#arrow)" />
        <!-- the recursion: portfolio emits /metrics → VM, VM scrapes it back -->
        <path class="edge edge--accent" d="M622,244 H696" marker-end="url(#arrowA)" />
        <path class="edge edge--accent" d="M771,276 C771,330 547,330 547,276" marker-end="url(#arrowA)" />

        <text class="edge-label" x="211" y="70" text-anchor="middle">push</text>
        <text class="edge-label" x="435" y="70" text-anchor="middle">mirror</text>
        <text class="edge-label" x="659" y="70" text-anchor="middle">build</text>
        <text class="edge-label" x="331" y="164" text-anchor="start">watches</text>
        <text class="edge-label" x="650" y="152" text-anchor="middle">image</text>
        <text class="edge-label" x="435" y="238" text-anchor="middle">deploys</text>
        <text class="edge-label edge-label--accent" x="650" y="238" text-anchor="middle">/metrics</text>
        <text class="edge-label edge-label--accent" x="659" y="326" text-anchor="middle">scrapes</text>
      </g>

      <!-- Nodes -->
      {nodes.map((n) => (
        <g class={`node node--${n.kind}`} transform={`translate(${n.x},${n.y})`}
           data-node={n.id} tabindex="0" role="button"
           aria-label={`${n.label} — ${n.sub}. Activate for detail.`}>
          <rect width={NODE_W} height={NODE_H} rx="4" class="node__box" />
          <text x="14" y="27" class="node__label">{n.label}</text>
          <text x="14" y="47" class="node__sub" data-rate={n.id === 'portfolio' ? '' : undefined}>{n.sub}</text>
          {n.kind !== 'identity' && (
            <circle cx={NODE_W - 16} cy="18" r="5" class="node__dot" data-dot={n.id} />
          )}
        </g>
      ))}
    </svg>

    <!-- Mobile + screen readers: the same graph as an outline. -->
    <ul class="topo__outline" aria-label="Homelab topology, outline view">
      {nodes.map((n) => (
        <li class={`o-row o-row--${n.kind}`} data-node={n.id} tabindex="0" role="button"
            aria-label={`${n.label} — ${n.sub}. Activate for detail.`}>
          {n.kind !== 'identity'
            ? <span class="o-dot" data-dot={n.id} aria-hidden="true"></span>
            : <span class="o-dot o-dot--id" aria-hidden="true"></span>}
          <span class="o-name">{n.label}</span>
          <span class="o-status" data-status={n.id}>{n.id === 'portfolio' ? '— req/s' : n.sub}</span>
        </li>
      ))}
    </ul>
  </div>

  <p class="topo__caption">
    Everything above runs on one k3s cluster I operate. This page is the
    <strong>portfolio</strong> node — a single Go binary, embedded static
    front-end, served by the very system it’s monitoring.
  </p>

  <div class="topo__foot">
    <p class="topo__legend"><span class="lg lg--ok"></span> live-probed · <span class="lg lg--infra"></span> cluster-reported · select a node for detail</p>
    <nav class="topo__nav" aria-label="Primary">
      <a href="/cv/">CV</a>
      <a href="/about/">About</a>
      <a href="https://git.henrydowd.dev/henry/portfolio" target="_blank" rel="noopener">Source</a>
    </nav>
  </div>

  <dialog class="topo__panel">
    <article>
      <header class="panel__head">
        <h2 data-panel-title>—</h2>
        <button class="panel__close" data-panel-close aria-label="Close">✕</button>
      </header>
      <p class="panel__role" data-panel-role></p>
      <p class="panel__body" data-panel-body></p>
      <a class="panel__link" data-panel-link hidden>Open →</a>
    </article>
  </dialog>
</section>

<!-- Live wiring lives in a same-origin external module (public/topology.js) so
     the CSP can stay `script-src 'self'` with no inline allowance. -->
<script type="module" src="/topology.js"></script>

<style>
  /* Schematic identity, scoped to the home view. /cv and /about keep their own
     editorial styling until the full overhaul. Health colours (--ok/--warn/
     --err) and --mono/--ink come from global.css. */
  .topo {
    --canvas: #f3f5f2;
    --edge: #aab0a8;
    --node-surface: #ffffff;
    --node-line: #d7dbd2;
    --grid: #e4e8e0;
  }
  @media (prefers-color-scheme: dark) {
    .topo {
      --canvas: #0f110d;
      --edge: #3c4138;
      --node-surface: #181a13;
      --node-line: #2e322a;
      --grid: #1a1d16;
    }
  }

  .topo__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .topo__kicker {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 0 0 0.35rem;
  }
  .topo__title { font-size: clamp(2rem, 6vw, 3rem); margin: 0; }
  .topo__live {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--ink-soft);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
  }
  .topo__dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--ink-soft); flex: none;
  }
  .topo__dot.is-ok { background: var(--ok); }
  .topo__dot.is-warn { background: var(--warn); }
  .topo__dot.is-err { background: var(--err); }

  /* ---- Stage ---- */
  .topo__stage {
    background: var(--canvas);
    background-image: radial-gradient(var(--grid) 1px, transparent 1px);
    background-size: 22px 22px;
    border: 1px solid var(--node-line);
    border-radius: 14px;
    padding: 0.75rem;
  }
  .topo__svg { display: block; width: 100%; height: auto; }

  .edge { stroke: var(--edge); stroke-width: 1.5; fill: none; }
  .edge--accent { stroke: var(--accent); stroke-width: 1.75; }
  .arrowhead { fill: var(--edge); }
  .arrowhead--accent { fill: var(--accent); }
  .edge-label {
    font-family: var(--mono); font-size: 11px; fill: var(--ink-soft);
    letter-spacing: 0.02em;
  }
  .edge-label--accent { fill: var(--accent); }

  .node { cursor: pointer; }
  .node__box {
    fill: var(--node-surface);
    stroke: var(--node-line);
    stroke-width: 1.5;
    transition: stroke 0.15s ease;
  }
  .node:hover .node__box,
  .node:focus-visible .node__box { stroke: var(--accent); }
  .node:focus { outline: none; }
  .node:focus-visible .node__box { stroke-width: 2.5; }
  .node__label {
    font-family: var(--mono); font-size: 15px; font-weight: 600;
    fill: var(--ink);
  }
  .node__sub {
    font-family: var(--mono); font-size: 11.5px;
    fill: var(--ink-soft); font-variant-numeric: tabular-nums;
  }
  .node--identity .node__box { fill: transparent; stroke: var(--accent); stroke-width: 2; }
  .node--identity .node__label { fill: var(--accent); }
  .node--self .node__box { stroke: var(--accent); stroke-width: 2; }
  .node--self .node__sub { fill: var(--accent); }

  .node__dot { fill: var(--ink-soft); }
  .node__dot.is-ok { fill: var(--ok); }
  .node__dot.is-warn { fill: var(--warn); }
  .node__dot.is-err { fill: var(--err); }
  .node__dot.is-live { animation: topo-pulse 2.4s ease-in-out infinite; }
  @keyframes topo-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  /* ---- Outline (mobile + screen readers) ---- */
  .topo__outline { display: none; list-style: none; margin: 0; padding: 0; }
  .o-row {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: baseline;
    gap: 0.7rem;
    padding: 0.7rem 0.4rem;
    border-bottom: 1px solid var(--node-line);
    cursor: pointer;
    font-family: var(--mono);
  }
  .o-row:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .o-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--ink-soft); align-self: center; }
  .o-dot.is-ok { background: var(--ok); }
  .o-dot.is-warn { background: var(--warn); }
  .o-dot.is-err { background: var(--err); }
  .o-dot--id { background: var(--accent); }
  .o-name { font-weight: 600; color: var(--ink); }
  .o-status { font-size: 0.8rem; color: var(--ink-soft); text-align: right; }

  /* ---- Caption + foot ---- */
  .topo__caption {
    color: var(--ink-soft); font-size: 0.98rem; max-width: 46rem;
    margin: 1.25rem 0 0;
  }
  .topo__caption strong { color: var(--ink); font-family: var(--mono); font-weight: 600; }
  .topo__foot {
    display: flex; justify-content: space-between; align-items: center;
    gap: 1rem; flex-wrap: wrap; margin-top: 1.25rem;
  }
  .topo__legend {
    font-family: var(--mono); font-size: 0.78rem; color: var(--ink-soft);
    margin: 0; display: inline-flex; align-items: center; gap: 0.4rem;
  }
  .lg { width: 9px; height: 9px; border-radius: 50%; display: inline-block; }
  .lg--ok { background: var(--ok); }
  .lg--infra { background: var(--ink-soft); }
  .topo__nav { display: flex; gap: 1.1rem; font-family: var(--mono); font-size: 0.92rem; }

  /* ---- Detail dialog ---- */
  .topo__panel {
    border: 1px solid var(--node-line);
    border-radius: 12px;
    padding: 0;
    max-width: 30rem;
    width: calc(100% - 2rem);
    background: var(--surface);
    color: var(--ink);
  }
  .topo__panel::backdrop { background: color-mix(in srgb, var(--ink) 45%, transparent); }
  .topo__panel article { padding: 1.25rem 1.4rem 1.5rem; }
  .panel__head { display: flex; align-items: center; justify-content: space-between; }
  .panel__head h2 { margin: 0; font-family: var(--mono); font-size: 1.15rem; }
  .panel__close {
    border: none; background: none; color: var(--ink-soft); cursor: pointer;
    font-size: 1rem; padding: 0.2rem 0.4rem;
  }
  .panel__close:hover { color: var(--ink); }
  .panel__role {
    font-family: var(--mono); font-size: 0.78rem; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--accent); margin: 0.1rem 0 0.8rem;
  }
  .panel__body { margin: 0 0 1rem; color: var(--ink-soft); }
  .panel__link { font-family: var(--mono); font-size: 0.9rem; }

  /* Swap diagram ↔ outline at the narrow breakpoint, so the a11y tree only ever
     contains one of them. */
  @media (max-width: 640px) {
    .topo__svg { display: none; }
    .topo__outline { display: block; }
    .topo__stage { background: none; border: none; padding: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .node__dot.is-live { animation: none; }
    .node__box { transition: none; }
  }
</style>
