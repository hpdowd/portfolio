---
/**
 * Base layout: the HTML shell shared by every page — metadata, social tags,
 * global styles, and the site footer. Pages render their content into the slot.
 */
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Use the wide editorial container (home only); reading pages stay narrow. */
  wide?: boolean;
}

const {
  title = 'Henry Dowd — Infrastructure Engineer',
  description =
    'Henry Dowd, a Pure Mathematics & Computer Science graduate targeting infrastructure engineering / systems / SRE roles, with a self-hosted Kubernetes homelab. This site runs on that cluster, with live telemetry from it.',
  wide = false,
} = Astro.props;

const year = new Date().getFullYear();

// Canonical / OG URL for the current page (Astro.site is set in astro.config.mjs).
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Social / Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Henry Dowd — Infrastructure Engineer" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site)} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="Henry Dowd — Homelab notes" href="/rss.xml" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <main id="main" class={wide ? 'main--wide' : undefined}>
      <slot />
    </main>
    <footer class={wide ? 'footer footer--wide' : 'footer'}>
      <span>© {year} Henry Dowd</span>
      <span>self-hosted on k3s · deployed by GitOps</span>
    </footer>
  </body>
</html>
