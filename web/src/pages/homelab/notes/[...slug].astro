---
/**
 * A single homelab note. Renders the Markdown body inside the shared page
 * chrome. Notes live under /homelab/notes/ because they are write-ups about the
 * homelab, not a peer section. Drafts are built (reachable by URL for review)
 * but carry a visible banner and are excluded from the index, RSS and sitemap.
 */
import Base from '../../../layouts/Base.astro';
import PageNav from '../../../components/PageNav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('writing');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, date, draft } = entry.data;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-IE', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base wide title={`${title} — Henry Dowd`} description={description}>
  <PageNav current="homelab" />
  <article class="note reading">
    {draft && (
      <p class="draft-banner">Draft — not published. Visible by URL only.</p>
    )}
    <header class="note__head">
      <p class="note__kicker"><a href="/homelab/">Homelab</a> · note</p>
      <h1>{title}</h1>
      <time class="note__date" datetime={date.toISOString()}>{fmt(date)}</time>
    </header>
    <div class="prose">
      <Content />
    </div>
    <p class="note__back"><a href="/homelab/">← Back to the homelab</a></p>
  </article>
</Base>

<style>
  .note { font-family: var(--sans); }
  .draft-banner {
    font-family: var(--mono); font-size: 0.75rem; color: var(--warn);
    border: 1px solid var(--warn); padding: 0.5rem 0.8rem; margin: 0 0 1.5rem;
  }
  .note__head { margin: 0 0 2rem; }
  .note__kicker {
    font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ink-soft); margin: 0 0 0.7rem;
  }
  .note__kicker a { color: var(--ink-soft); text-decoration: none; }
  .note__kicker a:hover { color: var(--accent); }
  .note__head h1 { font-size: clamp(2rem, 5vw, 2.9rem); margin: 0; letter-spacing: -0.02em; line-height: 1.1; }
  .note__date {
    display: block; font-family: var(--mono); font-size: 0.78rem;
    color: var(--ink-soft); margin-top: 0.8rem; font-variant-numeric: tabular-nums;
  }

  /* Rendered Markdown. Serif prose, generous measure. Scoped, so the injected
     HTML is reached with :global under .prose. */
  .prose :global(p) { font-family: var(--serif); font-size: 1.18rem; line-height: 1.62; margin: 0 0 1.3rem; }
  .prose :global(p:first-child) { margin-top: 0; }
  .prose :global(h2) {
    font-family: var(--mono); font-size: 0.8rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-soft);
    margin: 2.25rem 0 1rem; padding-top: 1.75rem; border-top: 1px solid var(--line);
  }
  .prose :global(a) { color: var(--accent); text-underline-offset: 3px; }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(code) {
    font-family: var(--mono); font-size: 0.86em;
    background: var(--surface); padding: 0.1rem 0.35rem; border: 1px solid var(--line);
  }

  .note__back { margin: 2.5rem 0 0; padding-top: 1.5rem; border-top: 1px solid var(--line); }
  .note__back a { font-family: var(--mono); font-size: 0.82rem; color: var(--ink); text-decoration: none; }
  .note__back a:hover { color: var(--accent); }
</style>
