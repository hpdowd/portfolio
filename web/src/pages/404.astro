---
/**
 * 404 — served (with a 404 status) by the Go static handler for any unknown
 * path. Same type system as the rest of the site; deliberately tiny.
 */
import Base from '../layouts/Base.astro';
import PageNav from '../components/PageNav.astro';
---

<Base
  title="404 — Henry Dowd"
  description="That page doesn't exist."
>
  <article class="notfound">
    <PageNav />
    <p class="notfound__code">404</p>
    <h1>Nothing here.</h1>
    <p class="notfound__lede">
      That path doesn't resolve, much like a request to a service that isn't
      scheduled. Let's route you back to something that is.
    </p>
  </article>
</Base>

<style>
  .notfound { font-family: var(--sans); max-width: 40rem; }
  .notfound__code {
    font-family: var(--mono); font-size: clamp(3rem, 12vw, 6rem); line-height: 1;
    color: var(--accent); margin: 0 0 0.5rem; letter-spacing: -0.02em;
  }
  .notfound h1 {
    font-size: clamp(2rem, 6vw, 3rem); margin: 0 0 1rem; letter-spacing: -0.02em;
  }
  .notfound__lede {
    font-family: var(--serif); font-size: clamp(1.15rem, 2.4vw, 1.4rem);
    line-height: 1.45; color: var(--ink-soft); margin: 0 0 2rem;
  }
</style>
