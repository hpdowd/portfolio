---
/**
 * CV — body content generated from web/cv/primary_cv.tex (the same source the
 * downloadable resume.pdf is compiled from), via `npm run cv:data` into
 * src/data/cv.ts. Edit the .tex, not this page, for anything in the sections
 * below; the masthead (name + contact) is decorative and stays here. Type
 * system matches the home: serif headings, mono labels/dates, sans body,
 * hairline section rules, one gruvbox accent.
 */
import Base from '../layouts/Base.astro';
import PageNav from '../components/PageNav.astro';
import { personLd } from '../data/site';
import { sections } from '../data/cv';

// JSON-LD Person, emitted on the CV for rich-result eligibility. Built from the
// shared identity source (src/data/site.ts), same node as the home @graph.
const cvPersonLd = personLd();
---

<Base
  wide
  title="CV — Henry Dowd"
  description="Henry Dowd, BSc in Pure Mathematics & Computer Science from Maynooth University, targeting graduate infrastructure engineering / systems / SRE roles."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(cvPersonLd)} />
  <PageNav current="cv" />
  <article class="cv reading">
    <header class="cv__head">
      <div class="cv__namerow">
        <h1>Henry Dowd</h1>
        <a class="cv__pdf" href="/resume.pdf" download>Download PDF ↓</a>
      </div>
      <p class="cv__contact">
        Ireland<span class="sep" aria-hidden="true">·</span>
        <a href="mailto:henry@dowd.ie">henry@dowd.ie</a><span class="sep" aria-hidden="true">·</span>
        <a href="https://www.linkedin.com/in/henrypdowd/" target="_blank" rel="noopener">linkedin.com/in/henrypdowd</a><span class="sep" aria-hidden="true">·</span>
        <a href="https://github.com/hpdowd" target="_blank" rel="noopener">github.com/hpdowd</a>
      </p>
    </header>

    {sections.map((sec) => (
      <section class="cv__sec">
        {sec.heading && <h2>{sec.heading}</h2>}
        {sec.blocks.map((block) =>
          block.kind === 'skills' ? (
            <dl class="cv__skills">
              {block.rows.map((row) => (
                <div><dt>{row.label}</dt><dd set:html={row.items} /></div>
              ))}
            </dl>
          ) : block.kind === 'entry' ? (
            <div class="cv__entry">
              <div class="cv__entryhead">
                <h3>
                  <Fragment set:html={block.title} />
                  {block.org && <span class="cv__org"> · {block.org}</span>}
                </h3>
                <span class="cv__dates">{block.dates}</span>
              </div>
              {block.subtitle && <p class="cv__sub">{block.subtitle}</p>}
              {block.bullets.length > 0 && (
                <ul>{block.bullets.map((b) => <li set:html={b} />)}</ul>
              )}
            </div>
          ) : (
            <p class="cv__prose" set:html={block.html} />
          )
        )}
      </section>
    ))}
  </article>
</Base>

<style>
  .cv { font-family: var(--sans); }
  .cv__namerow { display: flex; align-items: baseline; justify-content: space-between; gap: 0.6rem 1rem; flex-wrap: wrap; }
  .cv__pdf { font-family: var(--mono); font-size: 0.8rem; color: var(--accent); text-decoration: none; border: 1px solid var(--line); padding: 0.3rem 0.7rem; }
  .cv__pdf:hover { border-color: var(--accent); }

  .cv__head { margin-bottom: 0.5rem; }
  .cv__head h1 { font-size: clamp(2.4rem, 6vw, 3.4rem); margin: 0 0 0.6rem; letter-spacing: -0.02em; }
  /* Contact block: a single inline row, dot-separated. Four self-describing
     values (the URLs name their own platform) fit the reading measure without
     wrapping; on a narrow viewport it wraps gracefully at the separators. */
  .cv__contact { font-family: var(--mono); font-size: 0.84rem; color: var(--ink-soft); margin: 0; line-height: 1.8; }
  .cv__contact a { color: var(--ink); text-decoration: none; }
  .cv__contact a:hover { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .cv__contact .sep { margin: 0 0.55rem; color: var(--ink-soft); }

  .cv__sec { padding: 1.75rem 0; border-top: 1px solid var(--line); }
  .cv__sec > h2 {
    font-family: var(--mono); font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-soft);
    margin: 0 0 1.25rem;
  }

  .cv__skills div {
    display: grid; grid-template-columns: minmax(0, 12rem) 1fr; gap: 0.3rem 1.5rem;
    padding: 0.6rem 0; border-top: 1px solid var(--line);
  }
  .cv__skills div:first-child { border-top: 0; padding-top: 0; }
  .cv__skills dt { font-family: var(--mono); font-size: 0.78rem; letter-spacing: 0.03em; text-transform: uppercase; color: var(--ink-soft); margin: 0; }
  .cv__skills dd { margin: 0; font-family: var(--mono); font-size: 0.92rem; line-height: 1.5; }

  .cv__entry { margin-bottom: 1.6rem; }
  .cv__entry:last-child { margin-bottom: 0; }
  .cv__entryhead { display: flex; align-items: baseline; justify-content: space-between; gap: 0.3rem 1.25rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .cv__entry h3 { font-family: var(--serif); font-weight: 600; font-size: 1.28rem; line-height: 1.2; margin: 0; }
  .cv__org { font-family: var(--mono); font-size: 0.82rem; font-weight: 400; color: var(--ink-soft); }
  .cv__dates { font-family: var(--mono); font-size: 0.78rem; color: var(--ink-soft); font-variant-numeric: tabular-nums; white-space: nowrap; }
  .cv__sub { font-family: var(--mono); font-size: 0.82rem; color: var(--ink-soft); margin: 0 0 0.5rem; }
  /* Loose prose block (e.g. the Profile paragraph, the web-only modules line). */
  .cv__prose { line-height: 1.62; margin: 0.6rem 0 0; }
  .cv__prose:first-of-type { margin-top: 0; }

  .cv__entry ul { margin: 0.4rem 0 0; padding-left: 1.15rem; }
  .cv__entry li { margin-bottom: 0.45rem; line-height: 1.55; }
  .cv__entry li:last-child { margin-bottom: 0; }
  .cv__entry a, .cv p a { color: var(--accent); text-decoration: none; word-break: break-word; }
  .cv__entry a:hover, .cv p a:hover { text-decoration: underline; text-underline-offset: 3px; }
  .cv p { line-height: 1.62; margin: 0; }
</style>
