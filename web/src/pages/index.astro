---
/**
 * Home page — "Swiss / editorial, mono-led" direction (see Home.astro), the
 * replacement for the rejected Topology view. /cv and /about keep their current
 * styling until the overhaul reaches them.
 */
import Base from '../layouts/Base.astro';
import Home from '../components/Home.astro';
import { homeGraphLd } from '../data/site';

// JSON-LD for the home page: the site itself plus its author, for rich results
// and knowledge-graph eligibility. Built from the shared identity source in
// src/data/site.ts so it can't drift from the CV's Person node.
const homeLd = homeGraphLd();
---

<Base wide>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(homeLd)} />
  <Home />
</Base>
